---
import Layout from '../layouts/Layout.astro';
import BookingAssistant from '../components/react/BookingAssistant';
---

<Layout>
  <!-- ==================== NAVIGATION ==================== -->
  <nav id="main-nav" class="nav-glass fixed top-0 left-0 right-0 z-50 transition-shadow duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href="#" class="flex items-center gap-3">
        <!-- Barber Head Silhouette Logo -->
        <svg width="36" height="36" viewBox="0 0 40 40" fill="none" class="text-[var(--color-gold)]">
          <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <!-- Head silhouette -->
          <ellipse cx="20" cy="14" rx="7" ry="8" fill="currentColor"/>
          <!-- Beard -->
          <path d="M13 16 C13 24, 16 28, 20 29 C24 28, 27 24, 27 16" fill="currentColor"/>
          <!-- Mustache -->
          <path d="M15 18 Q17.5 20 20 18 Q22.5 20 25 18" stroke="var(--color-black)" stroke-width="1.2" fill="none"/>
        </svg>
        <span class="font-serif text-lg font-semibold tracking-wide text-[var(--color-cream)]">The Grand Barber</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="nav-link text-sm tracking-wide">Über uns</a>
        <a href="#services" class="nav-link text-sm tracking-wide">Leistungen</a>
        <a href="#gallery" class="nav-link text-sm tracking-wide">Galerie</a>
        <a href="#team" class="nav-link text-sm tracking-wide">Team</a>
        <a href="#booking" class="nav-link text-sm tracking-wide">Termin</a>
        <a href="tel:+41441234567" class="btn-gold text-sm !py-2.5 !px-6">Anrufen</a>
      </div>

      <button id="menu-toggle" class="md:hidden p-2 text-[var(--color-cream)]" aria-label="Menü öffnen">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu fixed inset-0 z-[60] bg-[var(--color-black)] flex flex-col items-center justify-center gap-8">
    <button id="menu-close" class="absolute top-6 right-6 p-2 text-[var(--color-cream)]" aria-label="Menü schliessen">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>
    <a href="#about" class="font-serif text-2xl text-[var(--color-cream)] hover:text-[var(--color-gold)] transition-colors">Über uns</a>
    <a href="#services" class="font-serif text-2xl text-[var(--color-cream)] hover:text-[var(--color-gold)] transition-colors">Leistungen</a>
    <a href="#gallery" class="font-serif text-2xl text-[var(--color-cream)] hover:text-[var(--color-gold)] transition-colors">Galerie</a>
    <a href="#team" class="font-serif text-2xl text-[var(--color-cream)] hover:text-[var(--color-gold)] transition-colors">Team</a>
    <a href="#booking" class="font-serif text-2xl text-[var(--color-cream)] hover:text-[var(--color-gold)] transition-colors">Termin</a>
    <a href="tel:+41441234567" class="btn-gold mt-4">Jetzt anrufen</a>
  </div>


  <!-- ==================== HERO ==================== -->
  <section class="hero-gradient min-h-screen flex items-center relative overflow-hidden">
    <div class="absolute top-20 right-0 w-72 h-72 bg-[var(--color-gold)]/5 rounded-full blur-3xl parallax-slow"></div>
    <div class="absolute bottom-20 left-0 w-72 md:w-96 h-72 md:h-96 bg-[var(--color-brown)]/30 rounded-full blur-3xl"></div>

    <div class="gold-particle" style="top: 15%; left: 20%; animation-delay: 0s;"></div>
    <div class="gold-particle" style="top: 30%; right: 10%; animation-delay: 1s; width: 6px; height: 6px;"></div>
    <div class="gold-particle" style="top: 60%; left: 10%; animation-delay: 2s;"></div>
    <div class="gold-particle" style="bottom: 25%; right: 10%; animation-delay: 3s; width: 5px; height: 5px;"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-32 md:py-0 grid md:grid-cols-2 gap-12 items-center relative z-10">
      <div class="text-center md:text-left">
        <div class="hero-text-reveal">
          <span class="section-subtitle block mb-4">Willkommen bei</span>
        </div>
        <h1 class="hero-text-reveal font-serif text-5xl sm:text-6xl lg:text-7xl font-bold leading-tight mb-6">
          The Grand<br/>
          <span class="text-[var(--color-gold)] italic">Barber</span>
        </h1>
        <div class="hero-text-reveal">
          <p class="text-[var(--color-warm-gray)] text-lg mb-8 max-w-lg mx-auto md:mx-0 leading-relaxed">
            Premium Barbershop für den modernen Gentleman in Zürich.
            Wo Tradition auf Handwerkskunst trifft — seit 2015.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
            <a href="#booking" class="btn-gold text-center">Termin buchen</a>
            <a href="tel:+41441234567" class="btn-outline-gold text-center flex items-center justify-center gap-2">
              <span class="phone-pulse inline-block">📞</span>
              +41 44 123 45 67
            </a>
          </div>
        </div>
      </div>

      <div class="hero-text-reveal hidden md:block">
        <div class="relative">
          <div class="w-full aspect-[3/4] rounded-3xl overflow-hidden shadow-2xl"
            style="background: linear-gradient(135deg, var(--color-dark-brown) 0%, var(--color-brown) 50%, var(--color-dark) 100%);">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center">
                <!-- Barber Pole Icon -->
                <svg width="60" height="120" viewBox="0 0 60 120" fill="none" class="mx-auto mb-4 opacity-40">
                  <rect x="10" y="0" width="40" height="120" rx="20" stroke="var(--color-gold)" stroke-width="2" fill="none"/>
                  <defs>
                    <clipPath id="pole-clip">
                      <rect x="11" y="1" width="38" height="118" rx="19"/>
                    </clipPath>
                  </defs>
                  <g clip-path="url(#pole-clip)">
                    <rect x="10" y="0" width="40" height="120" fill="white" opacity="0.15"/>
                    <line x1="-10" y1="10" x2="70" y2="-15" stroke="var(--color-red-barber)" stroke-width="8" opacity="0.5"/>
                    <line x1="-10" y1="30" x2="70" y2="5" stroke="var(--color-blue-barber)" stroke-width="8" opacity="0.5"/>
                    <line x1="-10" y1="50" x2="70" y2="25" stroke="var(--color-red-barber)" stroke-width="8" opacity="0.5"/>
                    <line x1="-10" y1="70" x2="70" y2="45" stroke="var(--color-blue-barber)" stroke-width="8" opacity="0.5"/>
                    <line x1="-10" y1="90" x2="70" y2="65" stroke="var(--color-red-barber)" stroke-width="8" opacity="0.5"/>
                    <line x1="-10" y1="110" x2="70" y2="85" stroke="var(--color-blue-barber)" stroke-width="8" opacity="0.5"/>
                    <line x1="-10" y1="130" x2="70" y2="105" stroke="var(--color-red-barber)" stroke-width="8" opacity="0.5"/>
                  </g>
                  <rect x="5" y="0" width="50" height="10" rx="5" fill="var(--color-gold)" opacity="0.6"/>
                  <rect x="5" y="110" width="50" height="10" rx="5" fill="var(--color-gold)" opacity="0.6"/>
                </svg>
                <span class="text-[var(--color-warm-gray)]/40 text-sm tracking-widest uppercase">Barbershop</span>
              </div>
            </div>
          </div>
          <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-[var(--color-gold)]/10 rounded-2xl -z-10"></div>
          <div class="absolute -top-4 -left-4 w-24 h-24 border-2 border-[var(--color-gold)]/20 rounded-2xl -z-10"></div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-60">
      <span class="text-xs text-[var(--color-warm-gray)] tracking-widest uppercase">Entdecken</span>
      <div class="w-px h-8 bg-gradient-to-b from-[var(--color-gold)] to-transparent animate-bounce"></div>
    </div>
  </section>


  <!-- ==================== ABOUT ==================== -->
  <section id="about" class="py-24 md:py-32 bg-[var(--color-dark)] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="reveal-left">
          <div class="relative">
            <div class="w-full aspect-[4/5] rounded-2xl"
              style="background: linear-gradient(160deg, var(--color-dark-brown), var(--color-brown-light));">
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-[var(--color-warm-gray)]/30 text-sm tracking-widest uppercase">Shop Interior</span>
              </div>
            </div>
            <div class="absolute -bottom-6 -right-6 bg-[var(--color-gold)] text-[var(--color-black)] p-6 rounded-2xl shadow-lg">
              <div class="text-3xl font-serif font-bold">10+</div>
              <div class="text-sm opacity-90">Jahre Erfahrung</div>
            </div>
          </div>
        </div>

        <div class="reveal-right">
          <span class="section-subtitle">Unsere Geschichte</span>
          <h2 class="section-title text-4xl md:text-5xl mt-3 mb-6">
            Wo Tradition auf<br/>
            <span class="text-[var(--color-gold)] italic">Handwerk</span> trifft
          </h2>
          <div class="gold-divider !mx-0 mb-6"></div>
          <p class="text-[var(--color-warm-gray)] leading-relaxed mb-4">
            The Grand Barber wurde 2015 von Marco Rossi mit einer klaren Vision gegründet:
            Ein Ort, an dem sich jeder Mann wie ein Gentleman fühlt. Im Herzen von
            Zürich-Enge gelegen, verbinden wir klassisches Barberhandwerk mit
            modernem Stil in einer Atmosphäre, die an die goldenen Zeiten erinnert.
          </p>
          <p class="text-[var(--color-warm-gray)] leading-relaxed mb-8">
            Unser Team aus drei erfahrenen Barbern beherrscht alles — vom klassischen
            Herrenschnitt über die perfekte Nassrasur bis hin zur kunstvollen
            Bartpflege. Wir verwenden ausschliesslich hochwertige Produkte und
            nehmen uns die Zeit, die Ihr Look verdient.
          </p>
          <div class="flex flex-wrap gap-8">
            <div>
              <div class="text-2xl font-serif font-bold text-[var(--color-gold)]">5'000+</div>
              <div class="text-sm text-[var(--color-warm-gray)]">Zufriedene Kunden</div>
            </div>
            <div>
              <div class="text-2xl font-serif font-bold text-[var(--color-gold)]">100%</div>
              <div class="text-sm text-[var(--color-warm-gray)]">Premiumprodukte</div>
            </div>
            <div>
              <div class="text-2xl font-serif font-bold text-[var(--color-gold)]">4.9 ★</div>
              <div class="text-sm text-[var(--color-warm-gray)]">Google Bewertung</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ==================== SERVICES & PRICING ==================== -->
  <section id="services" class="py-24 md:py-32 bg-[var(--color-black-soft)] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16 reveal">
        <span class="section-subtitle">Was wir bieten</span>
        <h2 class="section-title text-4xl md:text-5xl mt-3 mb-4">
          Unsere <span class="text-[var(--color-gold)] italic">Dienstleistungen</span>
        </h2>
        <div class="gold-divider mb-6"></div>
        <p class="text-[var(--color-warm-gray)] max-w-xl mx-auto">
          Vom klassischen Schnitt bis zur luxuriösen Nassrasur — wir bieten alles,
          was den modernen Gentleman ausmacht.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        <div class="service-card rounded-2xl p-8 reveal">
          <div class="service-icon w-14 h-14 rounded-xl bg-[var(--color-brown)] flex items-center justify-center mb-5">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-gold)]">
              <path d="M6.1 4C5 5.5 5.2 7.5 6.5 8.5c.5.5 1 .8 1.5 1-.5 1.5-1 3-1 4.5 0 3 2 5.5 5 5.5s5-2.5 5-5.5c0-1.5-.5-3-1-4.5.5-.2 1-.5 1.5-1C18.8 7.5 19 5.5 17.9 4"/>
              <circle cx="9" cy="6" r="1.5"/>
              <circle cx="15" cy="6" r="1.5"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2 text-[var(--color-cream)]">Herrenschnitt</h3>
          <p class="text-[var(--color-warm-gray)] text-sm mb-4 leading-relaxed">
            Der Klassiker — präziser Schnitt mit Beratung, Waschen und Styling.
            Von Fade über Undercut bis zum klassischen Seitenscheitel.
          </p>
          <div class="flex justify-between items-center pt-4 border-t border-[var(--color-brown-light)]">
            <span class="text-sm text-[var(--color-warm-gray)]">ca. 30 Min</span>
            <span class="text-[var(--color-gold)] font-serif font-semibold text-lg">CHF 55</span>
          </div>
        </div>

        <div class="service-card rounded-2xl p-8 reveal">
          <div class="service-icon w-14 h-14 rounded-xl bg-[var(--color-brown)] flex items-center justify-center mb-5">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-gold)]">
              <path d="M7 3c0 0 0 4 5 4s5-4 5-4"/>
              <path d="M4 17c0 0 2-4 8-4s8 4 8 4"/>
              <line x1="12" y1="7" x2="12" y2="13"/>
              <path d="M8 21h8"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2 text-[var(--color-cream)]">Nassrasur</h3>
          <p class="text-[var(--color-warm-gray)] text-sm mb-4 leading-relaxed">
            Die königliche Nassrasur mit heissem Tuch, Premium-Rasierschaum
            und Rasiermesser für die glatteste Rasur Ihres Lebens.
          </p>
          <div class="flex justify-between items-center pt-4 border-t border-[var(--color-brown-light)]">
            <span class="text-sm text-[var(--color-warm-gray)]">ca. 30 Min</span>
            <span class="text-[var(--color-gold)] font-serif font-semibold text-lg">CHF 50</span>
          </div>
        </div>

        <div class="service-card rounded-2xl p-8 reveal">
          <div class="service-icon w-14 h-14 rounded-xl bg-[var(--color-brown)] flex items-center justify-center mb-5">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-gold)]">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2 text-[var(--color-cream)]">Schnitt & Rasur Kombi</h3>
          <p class="text-[var(--color-warm-gray)] text-sm mb-4 leading-relaxed">
            Das Beste aus beiden Welten — perfekter Haarschnitt kombiniert
            mit einer klassischen Nassrasur. Das volle Barbershop-Erlebnis.
          </p>
          <div class="flex justify-between items-center pt-4 border-t border-[var(--color-brown-light)]">
            <span class="text-sm text-[var(--color-warm-gray)]">ca. 55 Min</span>
            <span class="text-[var(--color-gold)] font-serif font-semibold text-lg">CHF 90</span>
          </div>
        </div>

        <div class="service-card rounded-2xl p-8 reveal">
          <div class="service-icon w-14 h-14 rounded-xl bg-[var(--color-brown)] flex items-center justify-center mb-5">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-gold)]">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2 text-[var(--color-cream)]">Bart-Trimm & Kontur</h3>
          <p class="text-[var(--color-warm-gray)] text-sm mb-4 leading-relaxed">
            Professionelle Bartpflege — exaktes Trimmen, scharfe Konturen
            und Pflege mit hochwertigen Bartölen für den perfekten Look.
          </p>
          <div class="flex justify-between items-center pt-4 border-t border-[var(--color-brown-light)]">
            <span class="text-sm text-[var(--color-warm-gray)]">ca. 20 Min</span>
            <span class="text-[var(--color-gold)] font-serif font-semibold text-lg">CHF 35</span>
          </div>
        </div>

        <div class="service-card rounded-2xl p-8 reveal">
          <div class="service-icon w-14 h-14 rounded-xl bg-[var(--color-brown)] flex items-center justify-center mb-5">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-gold)]">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2 text-[var(--color-cream)]">Hot-Towel Treatment</h3>
          <p class="text-[var(--color-warm-gray)] text-sm mb-4 leading-relaxed">
            Luxuriöse Gesichtsbehandlung mit heissen Tüchern, Dampf und
            Premium-Pflege. Die perfekte Entspannung für den Gentleman.
          </p>
          <div class="flex justify-between items-center pt-4 border-t border-[var(--color-brown-light)]">
            <span class="text-sm text-[var(--color-warm-gray)]">ca. 25 Min</span>
            <span class="text-[var(--color-gold)] font-serif font-semibold text-lg">CHF 40</span>
          </div>
        </div>

        <div class="service-card rounded-2xl p-8 reveal">
          <div class="service-icon w-14 h-14 rounded-xl bg-[var(--color-brown)] flex items-center justify-center mb-5">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-gold)]">
              <circle cx="12" cy="8" r="5"/>
              <path d="M3 21c0-4.4 3.6-8 9-8s9 3.6 9 8"/>
              <path d="M15 5l2-3M9 5L7 2"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-2 text-[var(--color-cream)]">Grand Deluxe Paket</h3>
          <p class="text-[var(--color-warm-gray)] text-sm mb-4 leading-relaxed">
            Das Rundum-Erlebnis: Schnitt, Nassrasur, Bartpflege, Hot-Towel
            Treatment und Styling. Für den Mann, der alles verdient.
          </p>
          <div class="flex justify-between items-center pt-4 border-t border-[var(--color-brown-light)]">
            <span class="text-sm text-[var(--color-warm-gray)]">ca. 75 Min</span>
            <span class="text-[var(--color-gold)] font-serif font-semibold text-lg">CHF 140</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ==================== GALLERY ==================== -->
  <section id="gallery" class="py-24 md:py-32 bg-[var(--color-dark)] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16 reveal">
        <span class="section-subtitle">Unsere Arbeiten</span>
        <h2 class="section-title text-4xl md:text-5xl mt-3 mb-4">
          Die <span class="text-[var(--color-gold)] italic">Galerie</span>
        </h2>
        <div class="gold-divider mb-6"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 stagger-children">
        {['Classic Fade', 'Nassrasur', 'Beard Styling', 'Pompadour', 'Skin Fade', 'Gentleman Cut'].map((title, i) => (
          <div class={`gallery-item relative group reveal ${i === 0 ? 'md:row-span-2' : ''}`}>
            <div class={`w-full ${i === 0 ? 'h-full min-h-64 md:min-h-full' : 'aspect-square'} rounded-xl`}
              style={`background: linear-gradient(${135 + i * 20}deg, var(--color-dark-brown), var(--color-brown-light), var(--color-brown));`}>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-[var(--color-warm-gray)]/30 text-xs tracking-widest uppercase">{title}</span>
              </div>
            </div>
            <div class="gallery-overlay rounded-xl flex items-end p-5">
              <span class="text-white font-serif text-lg">{title}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ==================== TEAM ==================== -->
  <section id="team" class="py-24 md:py-32 bg-[var(--color-black-soft)] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16 reveal">
        <span class="section-subtitle">Die Experten</span>
        <h2 class="section-title text-4xl md:text-5xl mt-3 mb-4">
          Unser <span class="text-[var(--color-gold)] italic">Team</span>
        </h2>
        <div class="gold-divider mb-6"></div>
        <p class="text-[var(--color-warm-gray)] max-w-xl mx-auto">
          Drei leidenschaftliche Barber, die Ihr Haar und Ihren Bart in besten Händen halten.
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-8 stagger-children">
        <div class="team-card text-center reveal">
          <div class="team-img-wrapper w-48 h-48 mx-auto mb-6">
            <div class="w-full h-full rounded-full"
              style="background: linear-gradient(135deg, var(--color-dark-brown), var(--color-brown-light));">
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-[var(--color-warm-gray)]/30 text-xs tracking-widest uppercase">Foto</span>
              </div>
            </div>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-1 text-[var(--color-cream)]">Marco Rossi</h3>
          <p class="text-[var(--color-gold)] text-sm mb-3">Gründer & Master Barber</p>
          <p class="text-[var(--color-warm-gray)] text-sm leading-relaxed max-w-xs mx-auto">
            Mit über 15 Jahren Erfahrung und einer Leidenschaft für klassisches
            Barberhandwerk ist Marco das Herzstück von The Grand Barber.
          </p>
        </div>

        <div class="team-card text-center reveal">
          <div class="team-img-wrapper w-48 h-48 mx-auto mb-6">
            <div class="w-full h-full rounded-full"
              style="background: linear-gradient(135deg, var(--color-brown-light), var(--color-dark-brown));">
