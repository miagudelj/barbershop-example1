---
import config from '../config';
import SectionHeader from '../components/ui/SectionHeader.astro';

const { team, sections } = config;
const s = sections.team;
---

<section id="team" class="py-24 md:py-32 bg-[var(--color-bg-soft)] overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <SectionHeader
      subtitle={s.subtitle}
      title={s.title}
      titleHighlight={s.titleHighlight}
      titlePrefix="Unser"
      description={s.description}
    />

    <div class="grid sm:grid-cols-3 gap-8 stagger-children">
      {team.map((member) => (
        <div class="team-card text-center reveal">
          <div class="team-img-wrapper w-48 h-48 mx-auto mb-6">
            <img src={member.image} alt={member.name} class="w-full h-full rounded-full object-cover" loading="lazy"/>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-1 text-[var(--color-text)]">{member.name}</h3>
          <p class="text-[var(--color-primary)] text-sm mb-3">{member.role}</p>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed max-w-xs mx-auto">{member.bio}</p>
        </div>
      ))}
    </div>
  </div>
</section>
