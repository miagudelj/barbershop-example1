---
import config from '../config';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ServiceIcon from '../components/ui/ServiceIcon.astro';

const { services, sections } = config;
const s = sections.services;
---

<section id="services" class="py-24 md:py-32 bg-[var(--color-bg-soft)] overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <SectionHeader
      subtitle={s.subtitle}
      title={s.title}
      titleHighlight={s.titleHighlight}
      titlePrefix="Unsere"
      description={s.description}
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {services.map((service) => (
        <div class="service-card rounded-2xl p-8 reveal">
          <ServiceIcon icon={service.icon ?? 'haircut'} />
          <h3 class="font-serif text-xl font-semibold mb-2 text-[var(--color-text)]">{service.name}</h3>
          <p class="text-[var(--color-text-muted)] text-sm mb-4 leading-relaxed">{service.description}</p>
          <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border)]">
            <span class="text-sm text-[var(--color-text-muted)]">ca. {service.duration}</span>
            <span class="text-[var(--color-primary)] font-serif font-semibold text-lg">{service.price}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
