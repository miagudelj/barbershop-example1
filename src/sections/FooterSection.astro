---
import config from '../config';
const { business, contact, services, nav, footer } = config;
---

<footer class="bg-[var(--color-bg)] text-white/70 py-16 border-t border-[var(--color-border)]/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-10 mb-12">
      <div class="sm:col-span-2 md:col-span-1">
        <span class="font-serif text-xl text-[var(--color-text)] font-semibold">{business.name}</span>
        <p class="text-sm mt-3 leading-relaxed">{business.tagline}.</p>
      </div>

      <div>
        <h4 class="text-[var(--color-text)] font-medium mb-4 text-sm uppercase tracking-wider">Navigation</h4>
        <ul class="space-y-2 text-sm">
          {nav.links.map((link) => (
            <li><a href={link.href} class="hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-[var(--color-text)] font-medium mb-4 text-sm uppercase tracking-wider">Leistungen</h4>
        <ul class="space-y-2 text-sm">
          {services.slice(0, 5).map((service) => (
            <li>{service.name}</li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-[var(--color-text)] font-medium mb-4 text-sm uppercase tracking-wider">Kontakt</h4>
        <ul class="space-y-2 text-sm">
          <li>{contact.address.street}</li>
          <li>{contact.address.city}</li>
          <li><a href={`tel:${contact.phoneRaw}`} class="hover:text-[var(--color-primary)] transition-colors">{contact.phone}</a></li>
          <li><a href={`mailto:${contact.email}`} class="hover:text-[var(--color-primary)] transition-colors">{contact.email}</a></li>
        </ul>
      </div>
    </div>

    {footer.showBarberPoleStripe && (
      <div class="flex items-center gap-2 mb-8">
        <div class="flex-1 h-[3px] rounded-full" style={`background: repeating-linear-gradient(90deg, var(--color-decor-a) 0px, var(--color-decor-a) 20px, white 20px, white 40px, var(--color-decor-b) 40px, var(--color-decor-b) 60px, white 60px, white 80px); opacity: 0.3;`}></div>
      </div>
    )}

    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-center sm:text-left">
      <p class="text-xs text-white/40">{footer.copyright}</p>
      <div class="flex gap-4">
        {contact.social?.instagram && (
          <a href={contact.social.instagram} class="w-9 h-9 rounded-full border border-white/20 flex items-center justify-center hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all text-sm" aria-label="Instagram">IG</a>
        )}
        {contact.social?.facebook && (
          <a href={contact.social.facebook} class="w-9 h-9 rounded-full border border-white/20 flex items-center justify-center hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all text-sm" aria-label="Facebook">FB</a>
        )}
      </div>
    </div>
  </div>
</footer>
