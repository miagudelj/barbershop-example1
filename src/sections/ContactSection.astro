---
import config from '../config';
const { contact, hours, sections } = config;
const sectionLabels = sections.contact;
---

<section id="contact" class="py-24 md:py-32 bg-[var(--color-bg-card)] overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-2 gap-16">
      <div class="reveal-left">
        <span class="section-subtitle">{sectionLabels.subtitle}</span>
        <h2 class="section-title text-4xl md:text-5xl mt-3 mb-6">
          {sectionLabels.titleHighlight
            ? <>Besuchen Sie <span class="text-[var(--color-primary)] italic">{sectionLabels.titleHighlight}</span></>
            : sectionLabels.title
          }
        </h2>
        <div class="brand-divider !mx-0 mb-8"></div>

        <div class="space-y-6">
          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-[var(--color-bg-card-alt2)] flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-primary)]">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <h4 class="font-medium mb-1 text-[var(--color-text)]">Adresse</h4>
              <p class="text-[var(--color-text-muted)] text-sm">{contact.address.street}<br/>{contact.address.city}</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-[var(--color-bg-card-alt2)] flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-primary)]">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-medium mb-1 text-[var(--color-text)]">Telefon</h4>
              <a href={`tel:${contact.phoneRaw}`} class="text-[var(--color-primary)] hover:text-[var(--color-primary-light)] transition-colors text-sm">
                {contact.phone}
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-[var(--color-bg-card-alt2)] flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-primary)]">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div>
              <h4 class="font-medium mb-1 text-[var(--color-text)]">Öffnungszeiten</h4>
              <div class="text-[var(--color-text-muted)] text-sm space-y-1">
                {hours.regular.map((h) => (
                  <p>{h.days}: {h.time}</p>
                ))}
                <p>{hours.closedLabel}</p>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-[var(--color-bg-card-alt2)] flex items-center justify-center flex-shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-primary)]">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <h4 class="font-medium mb-1 text-[var(--color-text)]">E-Mail</h4>
              <a href={`mailto:${contact.email}`} class="text-[var(--color-primary)] hover:text-[var(--color-primary-light)] transition-colors text-sm">
                {contact.email}
              </a>
            </div>
          </div>
        </div>

        <div class="mt-10 p-6 rounded-2xl bg-gradient-to-r from-[var(--color-primary)]/10 to-[var(--color-bg-card-alt2)]/50 border border-[var(--color-primary)]/20">
          <p class="font-serif text-lg mb-3 text-[var(--color-text)]">Lieber persönlich?</p>
          <p class="text-[var(--color-text-muted)] text-sm mb-4">Rufen Sie uns an — wir beraten Sie gerne und finden den perfekten Termin für Sie.</p>
          <a href={`tel:${contact.phoneRaw}`} class="btn-primary inline-flex items-center gap-2">
            <span class="phone-pulse">📞</span>
            Jetzt anrufen
          </a>
        </div>
      </div>

      <div class="reveal-right">
        {contact.mapEmbedUrl ? (
          <iframe
            src={contact.mapEmbedUrl}
            class="w-full h-full min-h-[400px] rounded-xl border-2 border-[var(--color-border)]"
            style="border:0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        ) : (
          <div class="map-container w-full h-full min-h-[400px] relative"
            style={`background: linear-gradient(135deg, var(--color-bg-card-alt), var(--color-border));`}>
            <div class="absolute inset-0 flex items-center justify-center flex-col gap-4">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-primary)]/40">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              <span class="text-[var(--color-text-muted)]/40 text-sm tracking-widest uppercase">Google Maps</span>
              <span class="text-[var(--color-text-muted)]/30 text-xs">{contact.address.street}, {contact.address.city}</span>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
