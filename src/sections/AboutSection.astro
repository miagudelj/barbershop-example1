---
import config from '../config';
const { about } = config;

// Split title into parts around highlight word
const titleParts = about.title.split('\n');
---

<section id="about" class="py-24 md:py-32 bg-[var(--color-bg-card)] overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="reveal-left">
        <div class="relative">
          <div class="w-full aspect-[4/5] rounded-2xl overflow-hidden">
            <img src={about.image} alt={config.business.name} class="w-full h-full object-cover" loading="lazy"/>
          </div>
          {about.highlightBadge && (
            <div class="absolute -bottom-6 -right-6 bg-[var(--color-primary)] text-[var(--color-bg)] p-6 rounded-2xl shadow-lg">
              <div class="text-3xl font-serif font-bold">{about.highlightBadge.value}</div>
              <div class="text-sm opacity-90">{about.highlightBadge.label}</div>
            </div>
          )}
        </div>
      </div>

      <div class="reveal-right">
        <span class="section-subtitle">{about.subtitle}</span>
        <h2 class="section-title text-4xl md:text-5xl mt-3 mb-6">
          {titleParts.map((part, i) => {
            if (about.titleHighlight && part.includes(about.titleHighlight)) {
              const idx = part.indexOf(about.titleHighlight);
              return (
                <>
                  {i > 0 && <br/>}
                  {part.substring(0, idx)}
                  <span class="text-[var(--color-primary)] italic">{about.titleHighlight}</span>
                  {part.substring(idx + about.titleHighlight.length)}
                </>
              );
            }
            return <>{i > 0 && <br/>}{part}</>;
          })}
        </h2>
        <div class="brand-divider !mx-0 mb-6"></div>
        {about.paragraphs.map((p) => (
          <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">{p}</p>
        ))}
        <div class="flex flex-wrap gap-8 mt-4">
          {about.stats.map((stat) => (
            <div>
              <div class="text-2xl font-serif font-bold text-[var(--color-primary)]">{stat.value}</div>
              <div class="text-sm text-[var(--color-text-muted)]">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
